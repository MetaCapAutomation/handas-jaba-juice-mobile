{
  "expo": {
    "name": "Handas Jaba Juice",
    "slug": "handas-jaba-juice-mobile",
    "version": "1.0.0",
    "scheme": "handasjabajuice",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B1F3B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.handasjabajuice.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1B1F3B",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.handasjabajuice.mobile",
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "enableProguardInReleaseBuilds": true,
      "enableShrinkResourcesInReleaseBuilds": true,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#F5317F",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Handas Jaba Juice to access your photos to update your profile picture and attach images to support tickets.",
          "cameraPermission": "Allow Handas Jaba Juice to use your camera to take a profile picture."
        }
      ],
      "./plugins/withAbiSplits"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "da2603f4-4989-46e9-8d49-eefe16f95743"
      }
    },
    "owner": "metacap"
  }
}
